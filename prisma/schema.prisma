generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model WeightEntry {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique
  weight    Float
  note      String?
  createdAt DateTime @default(now())
}
